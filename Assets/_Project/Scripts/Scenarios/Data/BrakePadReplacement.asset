  m_Script: {fileID: 11500000, guid: 1ee901304fde05142b77b4428122940a, type: 3}
  m_Name: BrakePadReplacement
  m_EditorClassIdentifier: Assembly-CSharp::SkillForge.Core.ScenarioData
  scenarioName: "\u0417\u0430\u043C\u0435\u043D\u0430 \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0445
    \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u044B\u0445 \u043A\u043E\u043B\u043E\u0434\u043E\u043A"
  steps:
  - stepId: connect_scanner
    instruction: "\u041F\u043E\u0434\u043A\u043B\u044E\u0447\u0438\u0442\u0435 \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0441\u043A\u0430\u043D\u0435\u0440 \u043A \u0430\u0432\u0442\u043E\u043C\u043E\u0431\u0438\u043B\u044E"
    conditions:
    - {fileID: 0}
    requiredToolIds:
    - diagnostic_scanner
    highlightTargetId: diag_port
    isOptional: 0
  - stepId: scan_brakes
    instruction: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u0443\u044E
      \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043D\u0430 \u043F\u043B\u0430\u043D\u0448\u0435\u0442\u0435"
    conditions:
    - {fileID: 0}
    requiredToolIds: []
    highlightTargetId: brake_fluid_reservoir
    isOptional: 0
  - stepId: loosen_bolts
    instruction: "\u041E\u0442\u043A\u0440\u0443\u0442\u0438\u0442\u0435 \u0431\u043E\u043B\u0442\u044B
      \u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F \u043F\u0435\u0440\u0435\u0434\u043D\u0435\u0433\u043E
      \u0441\u0443\u043F\u043F\u043E\u0440\u0442\u0430"
    conditions:
    - {fileID: 0}
    requiredToolIds:
    - wrench
    highlightTargetId: bolt_caliper_front_left_01
    isOptional: 0
  - stepId: remove_caliper
    instruction: "\u0421\u043D\u0438\u043C\u0438\u0442\u0435 \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0439
      \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u043E\u0439 \u0441\u0443\u043F\u043F\u043E\u0440\u0442"
    conditions:
    - {fileID: 0}
    requiredToolIds:
    - wrench
    highlightTargetId: caliper_front_left
    isOptional: 0
  - stepId: remove_brake_pads
    instruction: "\u0418\u0437\u0432\u043B\u0435\u043A\u0438\u0442\u0435 \u0441\u0442\u0430\u0440\u044B\u0435
      \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u044B\u0435 \u043A\u043E\u043B\u043E\u0434\u043A\u0438"
    conditions:
    - {fileID: 0}
    requiredToolIds: []
    highlightTargetId: brake_pad_front_left
    isOptional: 0
  - stepId: remove_brake_disc
    instruction: "\u0421\u043D\u0438\u043C\u0438\u0442\u0435 \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u043E\u0439
      \u0434\u0438\u0441\u043A"
    conditions:
    - {fileID: 0}
    requiredToolIds:
    - hammer
    highlightTargetId: brake_disc_front_left
    isOptional: 0
  - stepId: install_brake_disc
    instruction: "\u0423\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0435 \u043D\u043E\u0432\u044B\u0439
      \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u043E\u0439 \u0434\u0438\u0441\u043A"
    conditions:
    - {fileID: 0}
    requiredToolIds: []
    highlightTargetId: brake_disc_front_left
    isOptional: 0
  - stepId: install_brake_pads
    instruction: "\u0423\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0435 \u043D\u043E\u0432\u044B\u0435
      \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u044B\u0435 \u043A\u043E\u043B\u043E\u0434\u043A\u0438"
    conditions:
    - {fileID: 0}
    requiredToolIds: []
    highlightTargetId: brake_pad_front_left
    isOptional: 0
  - stepId: install_caliper
    instruction: "\u0423\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0435 \u043E\u0431\u0440\u0430\u0442\u043D\u043E
      \u0442\u043E\u0440\u043C\u043E\u0437\u043D\u043E\u0439 \u0441\u0443\u043F\u043F\u043E\u0440\u0442"
    conditions:
    - {fileID: 0}
    requiredToolIds:
    - wrench
    highlightTargetId: caliper_front_left
    isOptional: 0
  - stepId: tighten_bolts
    instruction: "\u0417\u0430\u0442\u044F\u043D\u0438\u0442\u0435 \u0431\u043E\u043B\u0442\u044B
      \u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F \u0441\u0443\u043F\u043F\u043E\u0440\u0442\u0430
      \u0441 \u0443\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C"
